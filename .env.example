# Database
DATABASE_URL=postgresql+asyncpg://nexus:nexus_secret@postgres:5432/agent_nexus

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-this-to-a-random-secret-key

# Model API Keys (configure the ones you want to use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# Ollama (local models)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
